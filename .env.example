# OpenRouter config:
#   chat: google/gemini-2.5-flash
#   embedding: openai/text-embedding-3-large
#   judge: openai/gpt-4o-mini
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large
OPENROUTER_EMBEDDING_BATCH_SIZE=96
OPENROUTER_JUDGE_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=MRAgent
# Optional attribution header recommended by OpenRouter.
# OPENROUTER_HTTP_REFERER=https://github.com/your-name/MRAgent

EMBEDDING_PROVIDER=openrouter
JUDGE_PROVIDER=openrouter

# Ofox alternative.
OFOX_API_KEY=sk-xxxxxxxx
OFOX_BASE_URL=https://your-ofox-openai-compatible-endpoint/v1
OFOX_MODEL=google/gemini-2.5-flash
OFOX_RE_MODEL=google/gemini-2.5-flash
OFOX_EMBEDDING_MODEL=openai/text-embedding-3-large
OFOX_EMBEDDING_BATCH_SIZE=96
OFOX_JUDGE_MODEL=openai/gpt-4o-mini

# DeepSeek official API for chat and LLM-as-judge.
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_JUDGE_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING_MODE=disabled
LLM_TIMEOUT=300
LLM_REQUEST_MAX_RETRIES=8
LLM_BACKOFF=1.8
JUDGE_TIMEOUT=300
JUDGE_MAX_RETRIES=5

# Entity-attribute-memory retrieval mode.
EAES_INDEX_MODE=llm
EAES_PREFILTER_LIMIT=120
EAES_RERANK_LIMIT=30
EAES_TYPE_WEIGHT=0.15
EAES_PERSISTENCE_WEIGHT=0.05

# Local embedding model downloaded on AutoDL.
# Use this only when EMBEDDING_PROVIDER=local.
LOCAL_EMBEDDING_MODEL=/autodl-pub/models/bge-large-en-v1.5
LOCAL_EMBEDDING_BATCH_SIZE=32
