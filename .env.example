# Original paper-like Ofox config:
#   chat: google/gemini-2.5-flash
#   embedding: text-embedding-3-large
#   judge: openai/gpt-4o-mini
OFOX_API_KEY=sk-xxxxxxxx
OFOX_BASE_URL=https://your-ofox-openai-compatible-endpoint/v1
OFOX_MODEL=google/gemini-2.5-flash
OFOX_RE_MODEL=google/gemini-2.5-flash
EMBEDDING_PROVIDER=ofox
OFOX_EMBEDDING_MODEL=text-embedding-3-large
OFOX_EMBEDDING_BATCH_SIZE=96
JUDGE_PROVIDER=ofox
OFOX_JUDGE_MODEL=openai/gpt-4o-mini

# OpenRouter can still be used as an alternative OpenAI-compatible provider.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
OPENROUTER_EMBEDDING_MODEL=text-embedding-3-large
OPENROUTER_EMBEDDING_BATCH_SIZE=96
OPENROUTER_JUDGE_MODEL=openai/gpt-4o-mini

# DeepSeek official API for chat and LLM-as-judge.
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_JUDGE_MODEL=deepseek-v4-flash

# Local embedding model downloaded on AutoDL.
# Use this only when EMBEDDING_PROVIDER=local.
LOCAL_EMBEDDING_MODEL=/autodl-pub/models/bge-large-en-v1.5
LOCAL_EMBEDDING_BATCH_SIZE=32
